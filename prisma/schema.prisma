generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConversationSource {
  WEB
  WHATSAPP
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum VehicleStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum CrmUserRole {
  ADMIN
  SALES
}

model Conversation {
  id           String             @id @default(cuid())
  source       ConversationSource
  contactPhone String?
  contactName  String?
  contactEmail String?
  summary      String?
  sentiment    String?
  tags         String[]
  language     String?
  messageCount Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  messages     Message[]
  leads        Lead[]
  appointments Appointment[]
  events       ConversationEvent[]
  aiRatings    AIQualityRating[]
  satisfaction CustomerSatisfaction[]

  @@index([contactPhone])
  @@index([source])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String
  content        String
  toolName       String?
  toolArgs       Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

model Lead {
  id                 String             @id @default(cuid())
  conversationId     String?
  conversation       Conversation?      @relation(fields: [conversationId], references: [id])
  name               String
  email              String?
  phone              String?
  vehicleInterest    String?
  source             ConversationSource
  status             LeadStatus         @default(NEW)
  notes              String?
  budgetMin          Float?
  budgetMax          Float?
  timeline           String?
  tradeInVehicle     String?
  city               String?
  purchaseType       String?
  financingInterest  Boolean            @default(false)
  leadScore          Int                @default(0)
  qualificationLevel String?
  lastContactedAt    DateTime?
  assignedToId       String?
  assignedTo         CrmUser?           @relation("AssignedLeads", fields: [assignedToId], references: [id])
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  leadNotes          LeadNote[]

  @@index([status])
  @@index([phone])
  @@index([leadScore])
  @@index([assignedToId])
}

model Appointment {
  id              String            @id @default(cuid())
  conversationId  String?
  conversation    Conversation?     @relation(fields: [conversationId], references: [id])
  name            String
  email           String?
  phone           String?
  vehicle         String?
  preferredDate   DateTime?
  preferredTime   String?
  location        String?
  appointmentType String?
  status          AppointmentStatus @default(PENDING)
  notes           String?
  assignedToId    String?
  assignedTo      CrmUser?          @relation("AssignedAppointments", fields: [assignedToId], references: [id])
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@index([preferredDate])
  @@index([assignedToId])
}

model Vehicle {
  id          String        @id @default(cuid())
  model       String
  variant     String?
  color       String?
  status      VehicleStatus @default(AVAILABLE)
  price       Float?
  stockCount  Int           @default(0)
  description String?
  specs       Json?
  imageUrl    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([model, status])
}

model ConversationEvent {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  type           String
  detail         String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([type])
}

model CrmUser {
  id                  String      @id @default(cuid())
  email               String      @unique
  passwordHash        String
  name                String
  role                CrmUserRole @default(SALES)
  isActive            Boolean     @default(true)
  monthlyGoal         Int         @default(10)
  createdAt           DateTime    @default(now())
  assignedLeads       Lead[]      @relation("AssignedLeads")
  assignedAppointments Appointment[] @relation("AssignedAppointments")
  leadNotes           LeadNote[]
  aiRatings           AIQualityRating[]
}

// ===== NEW MODELS =====

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String
  vehicleModel String?
  discountType String?  // PERCENTAGE, FIXED, GIFT
  discountValue Float?
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([endDate])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([category])
}

model LeadNote {
  id        String   @id @default(cuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorId  String?
  author    CrmUser? @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@index([leadId])
}

model AIQualityRating {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  ratedById      String?
  ratedBy        CrmUser?     @relation(fields: [ratedById], references: [id])
  rating         Int          // 1-5
  feedback       String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([rating])
}

model CustomerSatisfaction {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  rating         Int          // 1-5
  comment        String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([rating])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // HOT_LEAD, NEW_APPOINTMENT, LEAD_INACTIVE, SYSTEM
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())

  @@index([isRead])
  @@index([userId])
  @@index([createdAt])
}